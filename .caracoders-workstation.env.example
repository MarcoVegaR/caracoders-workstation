# Copy this file to .caracoders-workstation.env and adjust locally.
# Never commit .caracoders-workstation.env.

CARACODERS_USER_NAME="Nombre Apellido"
CARACODERS_USER_EMAIL="usuario@caracoders.com"
GIT_AUTHOR_NAME="Nombre Apellido"
GIT_AUTHOR_EMAIL="usuario@caracoders.com"
GITHUB_USERNAME="usuario"

OPENCODE_PROVIDER="openai"
OPENCODE_API_KEY=""

MCP_FILESYSTEM_ALLOW_HOME="false"
MCP_FILESYSTEM_ALLOWED_PATHS="$HOME/projects,$HOME/caracoders"

INSTALL_VSCODE_EXTENSIONS="true"
INSTALL_STARSHIP_FONT="true"

# Explicit consent gates for --yes mode.
CARACODERS_ALLOW_DOCKER_APT_REPO="false"
CARACODERS_CONFIRM_DOCKER_GROUP="false"
CARACODERS_ALLOW_VSCODE_APT_REPO="false"
CARACODERS_CONFIRM_COPY_VSCODE_CONFIG="false"
CARACODERS_CONFIRM_BASHRC_BLOCK="false"
CARACODERS_CONFIRM_GITCONFIG="false"
CARACODERS_CONFIRM_OPENCODE_CONFIG="false"
CARACODERS_CONFIRM_MCP_HOME_ACCESS="false"
CARACODERS_CONFIRM_MCP_OUTSIDE_HOME_ACCESS="false"
CARACODERS_CONFIRM_STARSHIP_INSTALL="false"
CARACODERS_CONFIRM_STARSHIP_FONT="false"
CARACODERS_CONFIRM_ANYDESK="false"
CARACODERS_CONFIRM_ROLLBACK_DOTFILES="false"
CARACODERS_CONFIRM_OVERWRITE_EXISTING="false"
